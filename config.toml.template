# AI Brain — EU · config.toml
# Generated by setup.sh. Customize as needed.

[jurisdiction]
country = "EU"
citation_format = "ECLI"                                # e.g. "ECLI" for EU, with national variants
court_hierarchy = "../eu/_court_hierarchy.json"         # path to a JSON map of courts
bar_rules = "../eu/_bar_rules.md"                       # path to bar-rules markdown
timezone = "Europe/Brussels"                            # configurable per Member State, DST-aware

[paths]
statute_corpus = "../eu/_statute_corpus/"
drafting_corpus = "../eu/_drafting_data/"
audit_log_dir = "~/.ailawfirm_eu/audit_logs/"
matter_root = "~/.ailawfirm_eu/matters/"

[llm]
provider = "claude"                                      # v0.1 only supports claude
# In v0.3+: "openai" · "gemini_paid" · "ollama" · "byom"
